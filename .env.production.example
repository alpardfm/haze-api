APP_ENV=production
APP_TIMEZONE=Asia/Jakarta
AUTH_TOKEN_SECRET=replace-with-long-random-secret
AUTH_TOKEN_TTL_HOURS=24

POSTGRES_DB=haze_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://postgres:replace-with-strong-password@postgres:5432/haze_api?sslmode=disable

HOST_API_PORT=18081
REMINDER_WORKER_INTERVAL_SECONDS=60
STATUS_WORKER_INTERVAL_SECONDS=60

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=6281234567890
ADMIN_PASSWORD=replace-with-strong-admin-password

